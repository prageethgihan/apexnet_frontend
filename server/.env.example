# =============================================================================
# ApexNet LK — Backend  .env.example
# Copy this file to `.env` and fill in your real values.
# NEVER commit the actual .env to Git.
# =============================================================================

# ─── 3x-ui Panel Connection ───────────────────────────────────────────────────
# Full URL to your 3x-ui web panel (no trailing slash).
# If running behind Cloudflare Tunnel use the tunnel URL.
# Example (direct IP + port): http://95.181.160.194:2053/yourSubPath
# Example (CF Tunnel):        https://vpn.apexnetvpn.xyz
PANEL_URL=https://vpn.apexnetvpn.xyz

# Admin credentials for the 3x-ui panel
PANEL_USERNAME=admin
PANEL_PASSWORD=ApexNet2024!

# The inbound ID on 3x-ui that new VLESS clients will be added to
INBOUND_ID=1

# The port used in the generated VLESS URL (your VLESS inbound port)
INBOUND_PORT=10001

# ─── VPS Public IP ────────────────────────────────────────────────────────────
# This IP is embedded in every generated VLESS URL.
# It must be the public IP of your VPS (not the Cloudflare tunnel).
# Customers connect to this IP directly (SNI injection bypasses ISP block).
SERVER_IP=95.181.160.194

# ─── Express Server ───────────────────────────────────────────────────────────
PORT=5000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production example: https://apexnetvpn.xyz,http://localhost:5173
CORS_ORIGIN=https://apexnetvpn.xyz,http://localhost:5173

# ─── Optional: Firebase Admin SDK (for server-side token verification) ────────
# Uncomment and fill in only if you enable Firebase token verification.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# VERIFY_FIREBASE_TOKEN=false
